@page "/workoutsessions/new"
@using SportTracker.Core.Models
@inject HttpClient Http
@inject NavigationManager Nav

<div class="form-page">

    <div class="form-header">
        <a href="/workoutsessions" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
        <h1 class="form-title">Nouvelle séance</h1>
    </div>

    @if (availableExercises is null)
    {
        <p class="loading-text">Chargement des exercices...</p>
    }
    else if (!availableExercises.Any())
    {
        <div class="alert-card">
            Aucun exercice disponible.
            <a href="/exercises/new" class="alert-link">Créer un exercice →</a>
        </div>
    }
    else
    {
        <EditForm Model="form" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="field-group">
                <label class="field-label">Nom de la séance</label>
                <InputText class="field-input" @bind-Value="form.Name" placeholder="Ex : Push day" />
            </div>

            <div class="field-row">
                <div class="field-group">
                    <label class="field-label">Date</label>
                    <InputDate class="field-input" @bind-Value="form.Date" />
                </div>
                <div class="field-group">
                    <label class="field-label">Durée (min)</label>
                    <InputNumber class="field-input" @bind-Value="durationMinutes" min="1" />
                </div>
            </div>

            <div class="section-label">EXERCICES</div>

            @for (int i = 0; i < workoutExercises.Count; i++)
            {
                var idx = i;
                var we = workoutExercises[idx];

                <div class="exercise-block">
                    <div class="exercise-block__header">
                        <select class="field-input field-input--select" @bind="we.ExerciseId">
                            <option value="0">— Choisir un exercice —</option>
                            @foreach (var ex in availableExercises)
                            {
                                <option value="@ex.Id">@ex.Name</option>
                            }
                        </select>
                        <button type="button" class="remove-btn" @onclick="() => RemoveExercise(idx)">✕</button>
                    </div>

                    <div class="sets-header">
                        <span>SÉRIE</span><span>POIDS (kg)</span><span>REPS</span><span></span>
                    </div>

                    @for (int j = 0; j < we.Sets.Count; j++)
                    {
                        var setIdx = j;
                        var set = we.Sets[setIdx];
                        <div class="set-row">
                            <span class="set-num">@(setIdx + 1)</span>
                            <input type="number" class="set-input" @bind="set.Weight" min="0" step="0.5" placeholder="0" />
                            <input type="number" class="set-input" @bind="set.Repetitions" min="1" placeholder="0" />
                            <button type="button" class="set-remove" @onclick="() => RemoveSet(idx, setIdx)">✕</button>
                        </div>
                    }

                    <button type="button" class="add-set-btn" @onclick="() => AddSet(idx)">+ Série</button>
                </div>
            }

            <button type="button" class="add-exercise-btn" @onclick="AddExercise">+ Exercice</button>

            @if (errorMessage is not null)
            {
                <div class="error-card">@errorMessage</div>
            }

            <div class="form-actions">
                <button type="submit" class="submit-btn" disabled="@isSaving">
                    @(isSaving ? "Enregistrement..." : "Créer la séance")
                </button>
                <a href="/workoutsessions" class="cancel-btn">Annuler</a>
            </div>
        </EditForm>
    }

</div>

@code {
    private WorkoutSession form = new() { Date = DateTime.Today };
    private int durationMinutes = 60;
    private List<WorkoutExerciseForm> workoutExercises = new();
    private List<Exercise>? availableExercises;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        availableExercises = await Http.GetFromJsonAsync<List<Exercise>>("api/exercises");
    }

    private void AddExercise() => workoutExercises.Add(new WorkoutExerciseForm());
    private void RemoveExercise(int index) => workoutExercises.RemoveAt(index);
    private void AddSet(int exerciseIndex) => workoutExercises[exerciseIndex].Sets.Add(new ExerciseSet());
    private void RemoveSet(int exerciseIndex, int setIndex) => workoutExercises[exerciseIndex].Sets.RemoveAt(setIndex);

    private async Task HandleSubmit()
    {
        if (workoutExercises.Any(we => we.ExerciseId == 0))
        {
            errorMessage = "Sélectionne un exercice pour chaque ligne.";
            return;
        }
        isSaving = true;
        errorMessage = null;
        form.Duration = TimeSpan.FromMinutes(durationMinutes);
        form.WorkoutExercises = workoutExercises.Select(we => new WorkoutExercise
        {
            ExerciseId = we.ExerciseId,
            ExerciseSets = we.Sets
        }).ToList();
        var response = await Http.PostAsJsonAsync("api/workoutsessions", form);
        if (response.IsSuccessStatusCode)
            Nav.NavigateTo("/workoutsessions");
        else
        {
            errorMessage = $"Erreur lors de la création ({(int)response.StatusCode}).";
            isSaving = false;
        }
    }

    private class WorkoutExerciseForm
    {
        public int ExerciseId { get; set; }
        public List<ExerciseSet> Sets { get; set; } = new() { new ExerciseSet() };
    }
}
