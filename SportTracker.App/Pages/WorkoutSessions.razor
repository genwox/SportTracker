@page "/workoutsessions"
@using SportTracker.Core.Models
@inject HttpClient Http

<div class="workouts-page">

    <div class="workouts-header">
        <h1 class="workouts-title">
            <span class="title-eyebrow">Find your</span>
            Workouts
        </h1>
        <a href="/workoutsessions/new" class="new-btn">+ Nouvelle</a>
    </div>

    @if (sessions == null)
    {
        <div class="st-skel-block">
            <div class="st-skeleton st-skel-tall"></div>
            <div class="st-skeleton st-skel-tall"></div>
            <div class="st-skeleton st-skel-tall"></div>
        </div>
    }
    else if (!sessions.Any())
    {
        <div class="empty-state">
            <p class="empty-title">Aucune séance</p>
            <p class="empty-sub">Commence ta première séance de musculation.</p>
            <a href="/workoutsessions/new" class="empty-cta">+ Nouvelle séance</a>
        </div>
    }
    else
    {
        <div class="sessions-list">
            @foreach (var session in sessions.OrderByDescending(s => s.Date))
            {
                var exCount = session.WorkoutExercises?.Count ?? 0;
                var minutes = (int)session.Duration.TotalMinutes;

                <a href="/workoutsessions/@session.Id" class="session-card">
                    <div class="session-card__inner">
                        <div class="session-card__top">
                            <span class="session-card__date">@session.Date.ToString("dd MMM yyyy").ToUpper()</span>
                        </div>
                        <div class="session-card__bottom">
                            <div>
                                <h2 class="session-card__name">@session.Name</h2>
                                <div class="session-card__stats">
                                    <span class="stat-chip">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#D4F53C" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                        </svg>
                                        @(minutes > 0 ? $"{minutes} MIN" : "— MIN")
                                    </span>
                                    <span class="stat-chip">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#D4F53C" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M6 5v14"/><path d="M18 5v14"/><path d="M2 9h4"/><path d="M18 9h4"/><path d="M2 15h4"/><path d="M18 15h4"/><line x1="6" y1="9" x2="18" y2="9"/><line x1="6" y1="15" x2="18" y2="15"/>
                                        </svg>
                                        @exCount EXERCICE@(exCount > 1 ? "S" : "")
                                    </span>
                                </div>
                            </div>
                            <div class="session-card__play">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#172713" stroke="#172713" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="5 3 19 12 5 21 5 3"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
    }

</div>

@code {
    private List<WorkoutSession>? sessions;

    protected override async Task OnInitializedAsync()
    {
        sessions = await Http.GetFromJsonAsync<List<WorkoutSession>>("api/workoutsessions");
    }
}
