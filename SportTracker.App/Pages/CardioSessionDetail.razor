@page "/cardiosessions/{Id:int}"
@using SportTracker.Core.Models
@inject HttpClient Http
@inject NavigationManager Nav

<div class="detail-page">

@if (session is null && !notFound)
{
    <p class="loading-text">Chargement...</p>
}
else if (notFound)
{
    <div class="not-found">
        <p>Séance introuvable.</p>
        <a href="/history" class="back-btn">← Retour</a>
    </div>
}
else
{
    <div class="detail-header">
        <a href="/history" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
        <h1 class="detail-title">@session!.Name</h1>
    </div>

    <div class="hero-card">
        <p class="hero-label">@session.Type.ToString().ToUpper()</p>
        <p class="hero-value">@session.Distance.ToString("F1")</p>
        <p class="hero-unit">kilomètres</p>
    </div>

    <div class="stats-grid">
        <div class="stat-tile">
            <p class="stat-tile__val">@session.Duration.Hours h @session.Duration.Minutes min</p>
            <p class="stat-tile__lbl">Durée</p>
        </div>
        <div class="stat-tile">
            <p class="stat-tile__val">@session.Date.ToString("dd MMM yyyy")</p>
            <p class="stat-tile__lbl">Date</p>
        </div>
        @if (session.ElevationGain > 0)
        {
            <div class="stat-tile">
                <p class="stat-tile__val">@session.ElevationGain m</p>
                <p class="stat-tile__lbl">Dénivelé</p>
            </div>
        }
    </div>
}

</div>

@code {
    [Parameter] public int Id { get; set; }

    private CardioSession? session;
    private bool notFound;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/cardiosessions/{Id}");
        if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            notFound = true;
        else
            session = await response.Content.ReadFromJsonAsync<CardioSession>();
    }
}
