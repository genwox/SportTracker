@page "/workoutsessions/{Id:int}"
@using SportTracker.Core.Models
@inject HttpClient Http
@inject NavigationManager Nav

<div class="detail-page">

@if (session is null && !notFound)
{
    <p class="loading-text">Chargement...</p>
}
else if (notFound)
{
    <div class="not-found">
        <p>Séance introuvable.</p>
        <a href="/workoutsessions" class="back-btn">← Retour</a>
    </div>
}
else
{
    <div class="detail-header">
        <a href="/workoutsessions" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </a>
        <h1 class="detail-title">@session!.Name</h1>
    </div>

    <div class="meta-card">
        <div class="meta-grid">
            <div class="meta-item">
                <p class="meta-val">@session.Date.ToString("dd MMM yyyy")</p>
                <p class="meta-lbl">Date</p>
            </div>
            <div class="meta-item">
                <p class="meta-val">@session.Duration.Hours h @session.Duration.Minutes min</p>
                <p class="meta-lbl">Durée</p>
            </div>
            <div class="meta-item">
                <p class="meta-val">@(session.WorkoutExercises?.Count ?? 0)</p>
                <p class="meta-lbl">Exercices</p>
            </div>
        </div>
    </div>

    @if (session.WorkoutExercises is null || !session.WorkoutExercises.Any())
    {
        <p class="empty-text">Aucun exercice enregistré.</p>
    }
    else
    {
        <div class="exercises-list">
            @foreach (var we in session.WorkoutExercises)
            {
                <div class="exercise-card">
                    <p class="exercise-name">@(we.Exercise?.Name ?? $"Exercice #{we.ExerciseId}")</p>

                    @if (we.ExerciseSets is null || !we.ExerciseSets.Any())
                    {
                        <p class="no-sets">Aucune série.</p>
                    }
                    else
                    {
                        <div class="sets-header">
                            <span>SÉRIE</span>
                            <span>POIDS</span>
                            <span>REPS</span>
                        </div>
                        @for (int i = 0; i < we.ExerciseSets.Count; i++)
                        {
                            var set = we.ExerciseSets[i];
                            <div class="set-row @(i % 2 == 0 ? "" : "set-row--alt")">
                                <span class="set-num">@(i + 1)</span>
                                <span class="set-val">@set.Weight kg</span>
                                <span class="set-val">× @set.Repetitions</span>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    }
}

</div>

@code {
    [Parameter] public int Id { get; set; }

    private WorkoutSession? session;
    private bool notFound;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/workoutsessions/{Id}");
        if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            notFound = true;
        else
            session = await response.Content.ReadFromJsonAsync<WorkoutSession>();
    }
}
