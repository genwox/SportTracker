@page "/history"
@using SportTracker.Core.Models
@using SportTracker.Core.Enums
@inject HttpClient Http

<div class="history-page">

    <div class="history-header">
        <h1 class="history-title">
            <span class="title-eyebrow">Track your</span>
            History
        </h1>
        <button class="filter-btn @(filterOpen ? "filter-btn--active" : "")" @onclick="ToggleFilter">
            FILTER BY TYPE
        </button>
    </div>

    @if (filterOpen)
    {
        <div class="filter-chips">
            @foreach (var f in filters)
            {
                <button class="chip @(activeFilter == f ? "chip--active" : "")" @onclick="() => activeFilter = f">
                    @f
                </button>
            }
        </div>
    }

    @if (allItems == null)
    {
        <div class="st-skel-block">
            <div class="st-skeleton" style="height:70px"></div>
            <div class="st-skeleton" style="height:70px"></div>
            <div class="st-skeleton" style="height:70px"></div>
            <div class="st-skeleton" style="height:70px"></div>
        </div>
    }
    else if (!FilteredItems.Any())
    {
        <p class="empty-text">Aucune séance enregistrée.</p>
    }
    else
    {
        @foreach (var group in GroupedItems)
        {
            <div class="history-group">
                <p class="group-label">@group.Key</p>
                @foreach (var item in group)
                {
                    <a href="@item.DetailUrl" class="history-item">
                        <div class="icon-badge" style="background: @item.IconBg">
                            @((MarkupString)item.IconSvg)
                        </div>
                        <div class="item-info">
                            <p class="item-name">@item.Name</p>
                            <p class="item-meta">@item.Meta</p>
                        </div>
                        <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#CCC" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"/>
                        </svg>
                    </a>
                }
            </div>
        }
    }

    <div class="fab-row">
        <a href="/workoutsessions/new" class="fab">+ Muscu</a>
        <a href="/cardiosessions/new" class="fab">+ Cardio</a>
    </div>
</div>

@code {
    private record HistoryItem(
        string Name, DateTime Date, string Meta,
        string DetailUrl, string IconBg, string IconSvg, string Kind);

    private List<HistoryItem>? allItems;
    private bool filterOpen = false;
    private string activeFilter = "Tout";

    private static readonly string[] filters = ["Tout", "Muscu", "Cardio"];

    private IEnumerable<HistoryItem> FilteredItems => activeFilter switch
    {
        "Muscu"  => allItems?.Where(i => i.Kind == "workout") ?? [],
        "Cardio" => allItems?.Where(i => i.Kind == "cardio")  ?? [],
        _        => allItems ?? []
    };

    private IEnumerable<IGrouping<string, HistoryItem>> GroupedItems =>
        FilteredItems
            .OrderByDescending(i => i.Date)
            .GroupBy(i => GetPeriodLabel(i.Date));

    protected override async Task OnInitializedAsync()
    {
        var workoutsTask = Http.GetFromJsonAsync<List<WorkoutSession>>("api/workoutsessions");
        var cardioTask   = Http.GetFromJsonAsync<List<CardioSession>>("api/cardiosessions");

        await Task.WhenAll(workoutsTask, cardioTask);

        var items = new List<HistoryItem>();

        foreach (var s in workoutsTask.Result ?? [])
        {
            var duration = $"{(int)s.Duration.TotalMinutes} MIN";
            var exCount  = s.WorkoutExercises?.Count ?? 0;
            items.Add(new HistoryItem(
                s.Name, s.Date,
                $"{s.Date:dd MMM} • {duration} • {exCount} exercice{(exCount > 1 ? "s" : "")}",
                $"/workoutsessions/{s.Id}",
                "#D4F53C",
                DumbbellSvg("#172713"),
                "workout"));
        }

        foreach (var s in cardioTask.Result ?? [])
        {
            var duration = $"{(int)s.Duration.TotalMinutes} MIN";
            var (bg, iconColor, svg) = CardioIcon(s.Type);
            var distanceStr = s.Distance > 0 ? $" • {s.Distance:F1} km" : "";
            items.Add(new HistoryItem(
                s.Name, s.Date,
                $"{s.Date:dd MMM} • {duration}{distanceStr}",
                $"/cardiosessions/{s.Id}",
                bg,
                svg,
                "cardio"));
        }

        allItems = items;
    }

    private void ToggleFilter() => filterOpen = !filterOpen;

    private static string GetPeriodLabel(DateTime date)
    {
        var today    = DateTime.Today;
        var monday   = today.AddDays(-(int)today.DayOfWeek + (int)DayOfWeek.Monday);
        var lastMon  = monday.AddDays(-7);
        return date >= monday   ? "CETTE SEMAINE"
             : date >= lastMon  ? "SEMAINE DERNIÈRE"
             : "PLUS TÔT";
    }

    private static (string bg, string color, string svg) CardioIcon(CardioType type) => type switch
    {
        CardioType.Run  => ("#78E8E4", "#172713", ActivitySvg("#172713")),
        CardioType.Bike => ("#78E8E4", "#172713", ActivitySvg("#172713")),
        CardioType.Swim => ("#172713", "#D4F53C", ActivitySvg("#D4F53C")),
        CardioType.Walk => ("rgba(120,232,228,0.35)", "#172713", WindSvg("#172713")),
        _               => ("#78E8E4", "#172713", ActivitySvg("#172713")),
    };

    private static string DumbbellSvg(string color) =>
        $"""<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 5v14"/><path d="M18 5v14"/><path d="M2 9h4"/><path d="M18 9h4"/><path d="M2 15h4"/><path d="M18 15h4"/><line x1="6" y1="9" x2="18" y2="9"/><line x1="6" y1="15" x2="18" y2="15"/></svg>""";

    private static string ActivitySvg(string color) =>
        $"""<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>""";

    private static string WindSvg(string color) =>
        $"""<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="{color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>""";
}
